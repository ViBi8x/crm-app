{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18" // Giảm xuống 18 để tương thích với runtime phổ biến
  },
  "main": "lib/index.js",
  "dependencies": {
    "axios": "^1.6.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^4.0.0" // Nâng cấp để hỗ trợ v2
  },
  "devDependencies": {
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.7.3"
  },
  "private": true
}